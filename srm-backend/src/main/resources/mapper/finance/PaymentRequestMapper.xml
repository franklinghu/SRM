<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.srm.modules.finance.mapper.PaymentRequestMapper">

    <select id="selectPageList" resultType="com.srm.modules.finance.entity.PaymentRequest">
        SELECT * FROM payment_request
        <where>
            tenant_id = #{tenantId}
            <if test="requestNo != null and requestNo != ''">
                AND request_no LIKE CONCAT('%', #{requestNo}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>
